{
  "name": "countdown",
  "version": "1.0.0",
  "description": "Solver for the Countdown numbers game",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"website/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"website/**/*.ts\"",
    "precommit": "pnpm run format && pnpm run lint && pnpm run type-check && pnpm test",
    "generate:og-image": "node --import tsx/esm scripts/generate-og-image.ts",
    "generate:icons": "node --import tsx/esm scripts/generate-icons.ts",
    "prebuild": "pnpm run generate:icons && pnpm run generate:og-image",
    "dev": "vite website --config vite.config.ts",
    "build": "vite build website --config vite.config.ts",
    "preview": "vite preview website --config vite.config.ts",
    "lighthouse": "tsx scripts/run-lighthouse.ts"
  },
  "keywords": [
    "countdown",
    "numbers-game",
    "solver"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "lighthouse": "^13.4.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
